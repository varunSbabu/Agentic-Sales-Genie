{
  "manifest_version": 3,
  "name": "Sales Genie",
  "version": "1.0.0",
  "description": "AI-powered sales call intelligence — records, transcribes, and scores calls against your own frameworks.",
  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "scripting",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*.assemblyai.com/*",
    "https://app.zoom.us/*",
    "https://meet.google.com/*",
    "https://app.gong.io/*",
    "https://teams.microsoft.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.zoom.us/*",
        "https://meet.google.com/*",
        "https://app.gong.io/*",
        "https://teams.microsoft.com/*"
      ],
      "js": [
        "content/platform_extractors/zoom.js",
        "content/platform_extractors/meet.js",
        "content/platform_extractors/gong.js",
        "content/platform_extractors/generic.js",
        "content/content_script.js"
      ]
    }
  ],
  "action": {
    "default_popup": "sidebar/sidebar.html",
    "default_title": "Sales Genie",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "config/settings.html"
}
