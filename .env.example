# =============================================================================
# Sales Genie — environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- LLM provider switch -----------------------------------------------------
# Default provider for ALL agent nodes. Options: anthropic | groq | google
#   - anthropic: claude-sonnet-4-6 (paid; sign up at console.anthropic.com)
#   - groq:      llama-3.3-70b-versatile (FREE, no card; console.groq.com)
#   - google:    gemini-2.0-flash (FREE, no card; aistudio.google.com/apikey)
LLM_PROVIDER=groq

# Optional per-node overrides — route ONE expensive node to a stronger model
# while keeping cheaper ones on the free tier. Leave blank to fall back to
# LLM_PROVIDER above. Example: LLM_PROVIDER_SCORE=anthropic uses Claude for
# the scoring step (lower variance, ~$0.02/call) and free Llama for the rest.
LLM_PROVIDER_SCORE=
LLM_PROVIDER_CLASSIFY=
LLM_PROVIDER_COACH=

# --- Anthropic (paid) --------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Groq (free tier) --------------------------------------------------------
# Get a free API key at https://console.groq.com (no credit card required).
# Llama 3.3 70B supports function calling — needed for structured output.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- AssemblyAI (transcription) ----------------------------------------------
ASSEMBLYAI_API_KEY=

# --- Database (Supabase Postgres) --------------------------------------------
#
# Supabase exposes three connection endpoints. Use them as follows:
#
#   1. Direct connection      → db.[REF].supabase.co:5432           (IPv6-only in some regions)
#   2. Session-mode pooler    → aws-0-[REGION].pooler.supabase.com:5432   ← use for Alembic / Celery
#   3. Transaction-mode pooler→ aws-0-[REGION].pooler.supabase.com:6543   ← use for FastAPI app
#
# Why split: transaction-mode pgbouncer breaks prepared statements and some DDL.
# The app code below also passes statement_cache_size=0 to asyncpg so the
# transaction pooler works correctly.
#
# Note: username is `postgres.[PROJECT-REF]` when going through the pooler,
# not just `postgres`.

# Async URL — FastAPI app (transaction pooler, port 6543)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Sync URL — Alembic migrations + Celery (session pooler, port 5432)
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.[PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# --- Supabase API keys -------------------------------------------------------
# Project metadata
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_PROJECT_REF=[PROJECT-REF]

# New-style keys (Settings → API Keys page) — preferred for new projects
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy keys (Settings → API → Legacy anon/service_role tab) — still required
# by some libraries (e.g. supabase-py). Safe to leave blank if you're not using
# the Supabase client SDK and only need DB access.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Generic key used by supabase_connector for dashboard URLs — set to SECRET or SERVICE
SUPABASE_KEY=

# --- Redis (Celery broker + result backend) ----------------------------------
REDIS_URL=redis://redis:6379/0

# --- Cloudflare R2 (audio storage) -------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sales-genie-recordings
R2_PUBLIC_BASE_URL=

# --- SendGrid (email notifications) ------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@yourdomain.com
SENDGRID_FROM_NAME=Sales Genie

# --- LangSmith (agent observability) -----------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sales-genie
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Security ----------------------------------------------------------------
# JWT signing key — generate with: openssl rand -hex 32
JWT_SECRET_KEY=
# Fernet/AES-256 key for encrypting stored CRM tokens —
# generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# --- Slack -------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# --- App settings ------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
CHROMA_PERSIST_DIR=./chroma_db
EXTENSION_ORIGIN=chrome-extension://__REPLACE_WITH_EXTENSION_ID__
FRONTEND_URL=http://localhost:8000
